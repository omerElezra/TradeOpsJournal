# FastAPI backend config
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key

# Comma-separated allowed CORS origins (the Next.js app)
CORS_ORIGINS=http://localhost:3000

# Optional: verify Supabase-issued JWTs. Leave blank to disable auth in local dev.
SUPABASE_JWT_SECRET=
